# Notion Integration Token
# 1. Go to https://www.notion.so/my-integrations
# 2. Create an internal integration (name it "Local Sync" or similar)
# 3. Copy the token below
# 4. Share your Knowledge Hub page with the integration:
#    Open the page in Notion > ••• menu > Connections > Add "Local Sync"
# 5. Copy this file to .env:  cp .env.example .env

NOTION_API_TOKEN=ntn_your_token_here
